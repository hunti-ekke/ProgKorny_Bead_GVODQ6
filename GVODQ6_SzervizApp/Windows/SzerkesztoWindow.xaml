<Window x:Class="GVODQ6_SzervizApp.SzerkesztoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Munkalap szerkesztése" Height="350" Width="400" WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Ügyfél:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,10"/>
        <ComboBox x:Name="cmbUgyfelek" Grid.Row="0" Grid.Column="1" DisplayMemberPath="Nev" SelectedValuePath="UgyfelID" Margin="0,0,0,10"/>

        <TextBlock Text="Rendszám:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,10"/>
        <TextBox x:Name="txtRendszam" Grid.Row="1" Grid.Column="1" Margin="0,0,0,10"/>

        <TextBlock Text="Hiba leírása:" Grid.Row="2" Grid.Column="0" Margin="0,5,0,10"/>
        <TextBox x:Name="txtHiba" Grid.Row="2" Grid.Column="1" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,10"/>

        <TextBlock Text="Állapot:" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,20"/>
        <ComboBox x:Name="cmbAllapot" Grid.Row="3" Grid.Column="1" Margin="0,0,0,20">
            <ComboBoxItem Content="Folyamatban"/>
            <ComboBoxItem Content="Kész"/>
            <ComboBoxItem Content="Alkatrészre vár"/>
        </ComboBox>

        <Label x:Name="lblHibaUzenet" Grid.Row="4" Grid.ColumnSpan="2" Foreground="Red" FontWeight="Bold" Content="" HorizontalAlignment="Center" Margin="0,0,0,10"/>

        <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Mentés" Width="100" Margin="0,0,10,0" Click="btnMentes_Click" Background="Lime"/>
            <Button Content="Mégsem" Width="100" Click="btnMegsem_Click" Background="Red"/>
        </StackPanel>
    </Grid>
</Window>